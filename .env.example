# Donna Telegram Bot Configuration
# Copy to .env and fill in values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Harvey's Telegram Chat ID (security: only respond to this user)
HARVEY_CHAT_ID=your-chat-id-here

# Microsoft Graph Auth
GRAPH_APP_ID=14d82eec-204b-4c2f-b7e8-296a70dab67e
GRAPH_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47

# Feature Flags (1=on, 0=off)
FEATURE_BRIEFING=1
FEATURE_EMAIL=1
FEATURE_CALENDAR=1
FEATURE_PEOPLE=1
FEATURE_SEARCH=1
FEATURE_PR=0
FEATURE_FOOD=0
FEATURE_FOCUS=0

# GitHub (optional — for future GitHub integration)
GITHUB_TOKEN=your-github-pat-here
GITHUB_USERNAME=your-github-username
GITHUB_ORG=microsoft

# Azure DevOps (for PR Intelligence — set FEATURE_PR=1 to enable)
ADO_PAT=your-ado-personal-access-token
ADO_EMAIL=guptahemant@microsoft.com
# Semicolon-separated org/project/repo triples:
ADO_REPOS=powerbi/MWC/workload-fabriclivetable;msdata/HDInsight/your-repo;powerbi/Power BI/FeatureManagement;powerbi/Power BI/FabricSparkCST;msazure/One/AAD-FirstPartyApps

# Schedule (24h format, IST)
BRIEFING_HOUR=8
BRIEFING_MINUTE=30
EOD_HOUR=18
EOD_MINUTE=30
